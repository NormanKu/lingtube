{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/[[...path]].ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "data/**"
    }
  }
}
