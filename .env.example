OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=openai
PORT=3001

# Comma-separated list of allowed CORS origins. Defaults to localhost:5173 for dev.
ALLOWED_ORIGINS=

# Per-request and per-day caps on AI usage. Override if you have a higher budget.
AI_MAX_TOKENS_PER_REQUEST=80000
AI_MAX_CALLS_PER_DAY=50
